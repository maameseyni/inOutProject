rules_version = '2';
// Publier dans Firebase Console > Firestore > Règles > Publier
// (ou : firebase deploy --only firestore:rules si ce dépôt est lié à Firebase CLI)
//
// AVERTISSEMENT : allow read, write: if true = accès public tant que vous n'avez pas Firebase Auth.
// Quand l'inscription sera en place, restreindre avec request.auth != null et request.auth.uid == userId.

service cloud.firestore {
  match /databases/{database}/documents {

    match /transactions/{docId} {
      allow read, write: if true;
    }

    match /companyProfiles/{userId} {
      allow read, write: if true;
    }

    match /clientLists/{userId} {
      allow read, write: if true;
    }
  }
}
