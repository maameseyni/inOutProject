# Copier vers .env et adapter (ne jamais committer .env)
# cp .env.example .env

# --- Django ---
# Local : DJANGO_DEBUG=true  |  Production : DJANGO_DEBUG=false (défaut si absent)
DJANGO_DEBUG=true
# Obligatoire (pas de fallback). Générer :
#   python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,votre-domaine.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://votre-domaine.com,http://localhost:8000
# Ignoré si DJANGO_DEBUG=true ; en prod (DEBUG=false) laisser true derrière HTTPS
DJANGO_SECURE_SSL_REDIRECT=true
# Rate limiting (login, reset, écritures API). false uniquement pour tests locaux.
DJANGO_RATELIMIT_ENABLE=true

# --- PostgreSQL ---
POSTGRES_DB=xaliss
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# --- Google OAuth (application xaliss) ---
# Remplacer par les identifiants de VOTRE projet Google Cloud (ne pas committer les vrais secrets).
GOOGLE_CLIENT_ID=votre-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=votre-client-secret
